---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import SEOSchema from '../../components/SEOSchema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Office IT Solutions London | Workplace Technology Deployment & Microsoft 365"
  description="End-to-end workplace technology deployment in London. Hardware procurement, Microsoft 365 licensing, professional installation, ongoing support. Scalable solutions from 5 to 500+ users. Integration with IT buyback programs."
>
  <SEOSchema pageType="officeITSolutions" />

  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative py-10 md:py-16 bg-slate-900 text-white overflow-hidden border-b border-white/10">
      <!-- Ambient Background -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_rgba(0,74,173,0.3),_transparent)] opacity-40"></div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-12">
          <div class="flex-1 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/20 border border-blue-500/80 mb-6">
              <span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span>
              <span class="text-xs font-bold uppercase tracking-widest text-white">END-TO-END DEPLOYMENT</span>
            </div>
            <h1 class="text-4xl lg:text-6xl font-bold mb-6 leading-tight">
              Office IT Solutions
            </h1>
            <p class="text-xl text-cyan-100 mb-8 leading-relaxed max-w-2xl mx-auto lg:mx-0">
              End-to-end workplace technology deployment. Hardware procurement, software licensing, professional installation, ongoing support — delivered as a service.
            </p>
          </div>

          <div class="flex-1 w-full max-w-xl">
            <div class="relative group">
              <div class="absolute -inset-1 bg-gradient-to-r from-primary to-cyan-400 rounded-3xl blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
              <div class="relative bg-slate-800 rounded-2xl overflow-hidden shadow-2xl border border-white/10">
                <img src="/F3.png" alt="Office IT Solutions - End-to-end workplace technology deployment, hardware procurement, software licensing, professional installation and ongoing support" class="w-full h-auto object-cover transform transition duration-700 group-hover:scale-105" loading="lazy" decoding="async" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Block 1: What We Deliver -->
    <section class="py-20 bg-white mt-12">
      <div class="container mx-auto px-6 max-w-6xl">
        <div class="mb-12 text-center">
          <h2 class="text-3xl font-bold text-slate-900 mb-4">What We Deliver</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">💻</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Hardware Sourcing</h3>
            <p class="text-slate-600">Business-grade laptops, desktops, monitors, peripherals. Competitive pricing through MAR partnership.</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">📀</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Software Licensing</h3>
            <p class="text-slate-600">Microsoft 365, Windows OS, security suites. Genuine licenses, compliant deployment.</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🔧</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Professional Installation</h3>
            <p class="text-slate-600">On-site setup, network configuration, user accounts, security policies.</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🛟</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Ongoing Support</h3>
            <p class="text-slate-600">Helpdesk, maintenance, upgrades, asset tracking.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Block 2: How It Works -->
    <section class="py-20 bg-slate-50">
      <div class="container mx-auto px-6 max-w-6xl">
        <div class="mb-12 text-center">
          <h2 class="text-3xl font-bold text-slate-900 mb-4">How It Works</h2>
        </div>

        <div class="grid md:grid-cols-1 lg:grid-cols-5 gap-6">
          <div class="bg-white rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-bold">1</div>
            <h3 class="font-bold text-lg mb-3">Needs Assessment</h3>
            <p class="text-slate-600">Workspace audit, user requirements, budget planning</p>
          </div>

          <div class="bg-white rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-bold">2</div>
            <h3 class="font-bold text-lg mb-3">Solution Design</h3>
            <p class="text-slate-600">Hardware specs, software stack, deployment timeline</p>
          </div>

          <div class="bg-white rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-bold">3</div>
            <h3 class="font-bold text-lg mb-3">Procurement & Prep</h3>
            <p class="text-slate-600">Device imaging, security hardening, license activation</p>
          </div>

          <div class="bg-white rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-bold">4</div>
            <h3 class="font-bold text-lg mb-3">On-Site Deployment</h3>
            <p class="text-slate-600">Installation, configuration, user training</p>
          </div>

          <div class="bg-white rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 font-bold">5</div>
            <h3 class="font-bold text-lg mb-3">Handover & Support</h3>
            <p class="text-slate-600">Documentation, asset register, support contract</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Block 3: Why Antares -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-6 max-w-6xl">
        <div class="mb-12 text-center">
          <h2 class="text-3xl font-bold text-slate-900 mb-4">Why Antares</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-success-eco/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">📞</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Single Point of Contact</h3>
            <p class="text-slate-600">For hardware, software, and support</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-success-eco/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">📈</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Scalable Solutions</h3>
            <p class="text-slate-600">From 5-user offices to 500+ enterprise rollouts</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-success-eco/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">♻️</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Asset Recovery Integration</h3>
            <p class="text-slate-600">Future upgrades handled seamlessly</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-200">
            <div class="w-16 h-16 bg-success-eco/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🔒</span>
            </div>
            <h3 class="font-bold text-lg mb-3">Security-First Setup</h3>
            <p class="text-slate-600">Encrypted, patched, compliant from day one</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-r from-blue-600 to-cyan-800 text-white text-center">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold mb-4">Ready to Transform Your Workplace?</h2>
        <p class="text-cyan-200 mb-8">Contact an expert for end-to-end office IT solutions, hardware procurement, and professional installation services across the UK</p>
        <a href="/contacts" class="bg-success-eco text-black px-8 py-4 rounded-lg font-semibold hover:opacity-90 transition-opacity inline-block">
          Contact an Expert
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
