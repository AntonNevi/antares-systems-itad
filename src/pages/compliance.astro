---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SEOSchema from '../components/SEOSchema.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="NIST 800-88 & HMG IS5 Compliant ITAD Services | UK Data Destruction Compliance"
  description="Antares Systems provides NIST 800-88 and HMG IS5 compliant data destruction services in London and across the UK. ICO registered (ZC094526), waste carrier certified, WEEE compliant ITAD provider with secure data erasure, NIST 800-88 audit trails, and IT asset disposal compliance documentation."
>
  <SEOSchema pageType="compliance" />
  <Header />
  <main class="bg-slate-50 min-h-screen">
    <!-- Hero Section - Unified height across all pages -->
    <div class="bg-slate-900 py-12 md:py-16 text-center text-white border-b border-slate-800 min-h-[240px] sm:min-h-[260px] md:min-h-[280px] flex items-center">
      <div class="container mx-auto px-4 sm:px-6 max-w-4xl">
        <span class="inline-block px-3 py-1 rounded-full bg-success-eco/20 text-success-eco text-xs font-bold uppercase tracking-widest mb-4">Verified Compliance</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Your Data Protection is Our Business</h1>
        <p class="text-lg sm:text-xl text-slate-400"> Full regulatory adherence across data security, environmental standards, and liability coverage. </p>
      </div>
    </div>

    <!-- Content Section - Unified spacing -->
    <div class="container mx-auto px-4 sm:px-6 py-8 sm:py-12 mt-8 sm:mt-12 relative z-10 max-w-6xl">
      <!-- ESG & Sustainability Section -->
      <section class="mb-12 sm:mb-16">
        <div class="grid lg:grid-cols-2 gap-6 sm:gap-8">
          <!-- ESG Image Block -->
          <div class="rounded-3xl overflow-hidden shadow-sm border border-slate-200">
            <img
              src="/ESG.png"
              alt="Carbon-negative IT disposal and ESG-focused WEEE-compliant computer recycling with zero landfill commitment and environmental reporting"
              loading="lazy"
              decoding="async"
              class="w-full h-auto object-cover"
            />
          </div>
          <!-- ESG Content Block -->
          <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-slate-200">
            <h3 class="text-xl font-bold text-slate-900 mb-4">Carbon-Negative IT Disposal</h3>
            <p class="text-slate-600 leading-relaxed mb-6">
              Carbon-negative IT disposal with full environmental reporting. Zero landfill, circular economy certified ITAD solutions for UK enterprises and corporate sustainability initiatives.
            </p>
            <div class="space-y-3">
              <div class="flex items-center gap-2 text-sm font-medium text-slate-700">
                <span class="w-1.5 h-1.5 bg-success-eco rounded-full"></span>
                Zero Landfill Commitment
              </div>
              <div class="flex items-center gap-2 text-sm font-medium text-slate-700">
                <span class="w-1.5 h-1.5 bg-success-eco rounded-full"></span>
                Circular Economy Certified
              </div>
              <div class="flex items-center gap-2 text-sm font-medium text-slate-700">
                <span class="w-1.5 h-1.5 bg-success-eco rounded-full"></span>
                Carbon Footprint Reporting
              </div>
              <div class="flex items-center gap-2 text-sm font-medium text-slate-700">
                <span class="w-1.5 h-1.5 bg-success-eco rounded-full"></span>
                WEEE Compliant
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="grid lg:grid-cols-2 gap-6 sm:gap-8">
        <!-- Regulatory & Insurance Block -->
        <section class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-slate-200">
          <h2 class="text-xl sm:text-2xl font-bold text-slate-900 mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 sm:w-10 sm:h-10 text-blue-600">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            ACTIVE STATUS
          </h2>
          <div class="space-y-4 sm:space-y-6">
            <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">ICO Registered</span>
              <span class="text-lg font-mono font-bold text-slate-900">ZC094526</span>
            </div>
            <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Insurance</span>
              <span class="text-lg font-bold text-slate-900">Professional Indemnity & Public Liability</span>
              <p class="text-sm text-slate-500 mt-2">Waste Carrier & WEEE T11 — Application in Progress</p>
            </div>
          </div>
        </section>

        <!-- Security & Environmental Block -->
        <section class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-slate-200">
          <h2 class="text-xl sm:text-2xl font-bold text-slate-900 mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 sm:w-10 sm:h-10 text-blue-600">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            COMPLIANCE FRAMEWORK
          </h2>
          <div class="space-y-4">
            <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
              <h3 class="font-bold text-slate-900 mb-2">Data Security Standards</h3>
              <p class="text-sm text-slate-600">ADISA L2 Certified | Common Criteria EAL3+ | NIST 800-88 & IEEE 2883-2022 Compliant | NCSC Assured</p>
            </div>
            <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
              <h3 class="font-bold text-slate-900 mb-2">Environmental Compliance</h3>
              <p class="text-sm text-slate-600">Responsible IT Disposal with Full Environmental Audit Trails for ESG</p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>