---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article' | 'product';
  schema?: object;
}

const { 
  title, 
  description, 
  image = '/logo_antares.webp', 
  canonical, 
  type = 'website',
  schema
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
const socialImageURL = new URL(image, Astro.site).href;

// Default Organization Schema
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Antares Systems",
  "alternateName": "Antares Systems ITAD",
  "description": "London's trusted ITAD partner. Secure data destruction, certified IT asset disposal, and sustainable recycling.",
  "image": "https://antaressystems.net/logo_antares.webp",
  "telephone": "+44 7774 153420",
  "email": "info@antaressystems.net",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "CR2 8PD",
    "addressLocality": "London",
    "postalCode": "CR2 8PD",
    "addressCountry": "UK"
  },
  "url": "https://antaressystems.net",
  "priceRange": "££",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "opens": "09:00",
    "closes": "17:30"
  },
  "sameAs": [
    "https://linkedin.com/company/antares-systems"
  ]
};

const pageSchema = schema || defaultSchema;
---

<!doctype html>
<html lang="en-GB" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Favicon - Multi-format for maximum compatibility with absolute URLs for search engines -->
    <link rel="icon" type="image/x-icon" href="https://antaressystems.net/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="https://antaressystems.net/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="https://antaressystems.net/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="https://antaressystems.net/favicon_antares.png" />
    <link rel="icon" type="image/webp" sizes="48x48" href="https://antaressystems.net/favicon_antares.webp" />
    <link rel="icon" type="image/png" sizes="192x192" href="https://antaressystems.net/favicon_antares.png" />
    <link rel="icon" type="image/webp" sizes="512x512" href="https://antaressystems.net/favicon_antares.webp" />
    <link rel="apple-touch-icon" sizes="57x57" href="https://antaressystems.net/apple-touch-icon-57x57.png" />
    <link rel="apple-touch-icon" sizes="60x60" href="https://antaressystems.net/apple-touch-icon-60x60.png" />
    <link rel="apple-touch-icon" sizes="72x72" href="https://antaressystems.net/apple-touch-icon-72x72.png" />
    <link rel="apple-touch-icon" sizes="76x76" href="https://antaressystems.net/apple-touch-icon-76x76.png" />
    <link rel="apple-touch-icon" sizes="114x114" href="https://antaressystems.net/apple-touch-icon-114x114.png" />
    <link rel="apple-touch-icon" sizes="120x120" href="https://antaressystems.net/apple-touch-icon-120x120.png" />
    <link rel="apple-touch-icon" sizes="144x144" href="https://antaressystems.net/apple-touch-icon-144x144.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="https://antaressystems.net/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="https://antaressystems.net/apple-touch-icon-180x180.png" />
    <link rel="mask-icon" href="https://antaressystems.net/favicon_antares.svg" color="#004AAD" />
    <link rel="shortcut icon" href="https://antaressystems.net/favicon.ico" />
    <!-- Favicon for modern browsers -->
    <link rel="icon" href="https://antaressystems.net/favicon_antares.webp" type="image/webp" />
    <link rel="icon" href="https://antaressystems.net/favicon_antares.png" type="image/png" />
    <!-- Favicon for Google Search Console and major search engines -->
    <link rel="icon" href="https://antaressystems.net/favicon.ico" type="image/x-icon" />
    <link rel="alternate icon" href="https://antaressystems.net/favicon_antares.webp" type="image/webp" />
    <link rel="alternate icon" href="https://antaressystems.net/favicon_antares.png" type="image/png" />
    <!-- Specific favicon for Google to fix empty circle issue -->
    <link rel="icon" href="https://antaressystems.net/favicon_antares.webp" type="image/webp" title="Antares Systems" />
    <link rel="icon" href="https://antaressystems.net/favicon_antares.png" type="image/png" title="Antares Systems" />
    <!-- PWA Manifest with absolute URL -->
    <link rel="manifest" href="https://antaressystems.net/site.webmanifest" />
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Theme and App Settings -->
    <meta name="theme-color" content="#004AAD" />
    <meta name="msapplication-TileColor" content="#004AAD" />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <meta name="application-name" content="Antares Systems" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Antares Systems" />
    
    <!-- SEO -->
    <title>{title} | Antares Systems ITAD</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Antares Systems Ltd" />
    <meta name="generator" content="Antares Systems" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:site_name" content="Antares Systems" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE_HERE" />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Specific Google Favicon Fix -->
    <link rel="icon" href="https://antaressystems.net/favicon_antares.webp" type="image/webp" sizes="any" />
    <link rel="icon" href="https://antaressystems.net/favicon_antares.png" type="image/png" sizes="any" />
    <link rel="icon" href="https://antaressystems.net/favicon.ico" type="image/x-icon" sizes="any" />
    
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@2.0.0"></script>

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white text-slate-800 antialiased flex flex-col min-h-screen font-sans">
    <slot />
    
    <!-- Cookie Consent -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 bg-slate-900 border-t border-slate-800 p-4 transform translate-y-full transition-transform duration-300 z-50 text-sm hidden">
      <div class="container mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-slate-300">
          We use cookies to ensure GDPR compliance and analyze traffic. By continuing, you agree to our use of cookies.
        </p>
        <div class="flex gap-2">
          <button id="accept-cookies" class="px-4 py-2 bg-success-eco text-white rounded hover:bg-green-600 transition-colors">Accept</button>
          <button id="reject-cookies" class="px-4 py-2 bg-slate-700 text-white rounded hover:bg-slate-600 transition-colors">Necessary Only</button>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const banner = document.getElementById('cookie-banner');
        const accepted = localStorage.getItem('cookieconfig');
        
        if (!accepted) {
          banner.classList.remove('hidden');
          setTimeout(() => banner.classList.remove('translate-y-full'), 100);
        }

        document.getElementById('accept-cookies').addEventListener('click', () => {
          localStorage.setItem('cookieconfig', 'accepted');
          banner.classList.add('translate-y-full');
        });

        document.getElementById('reject-cookies').addEventListener('click', () => {
          localStorage.setItem('cookieconfig', 'rejected');
          banner.classList.add('translate-y-full');
        });
      });
    </script>
  </body>
</html>
